# Auth0 configuration for the Adotob MCP storefront sample integration.
#
# Copy to .env.local at the partner's app root, fill with values from the
# partner's Auth0 tenant, then load via the runtime's secret manager in
# production (Azure Key Vault, AWS Secrets Manager, Cloudflare Workers
# Secrets, etc.).
#
# These values are NEVER returned to the agent context. The middleware
# validates the token server-side and only exposes the principal id
# downstream.

# Auth0 tenant domain (without protocol). Example: "your-tenant.us.auth0.com"
AUTH0_DOMAIN=

# The API identifier (audience) configured on the Auth0 API resource.
# Example: "https://mcp.yourcompany.com/api"
AUTH0_AUDIENCE=

# Comma-separated list of scopes the middleware enforces at the request
# layer. Per-side-effect scope checks ALSO run in the route handler;
# this AUTH0_REQUIRED_SCOPES list is the floor (token must have at least
# these to even reach the route).
#
# Default scope vocabulary (one per side-effect category from the
# announce-intent-before-action discipline):
AUTH0_REQUIRED_SCOPES=read:bundles,write:contacts,send:transactional-email,mint:download-token,publish:receipt-url,charge:trial,enqueue:async-fulfillment
