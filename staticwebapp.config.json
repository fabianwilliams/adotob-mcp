{
  "platform": {
    "apiRuntime": "node:20"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/a2a/receipt/*", "/img/*", "/*.{png,jpg,ico,svg,css,js}"]
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "routes": [
    {
      "route": "/api/a2a/mcp",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/a2a/purchase",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/a2a/receipt/*",
      "allowedRoles": ["anonymous"]
    }
  ]
}
